# Bhetamla Configuration
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION - REQUIRED
# ═══════════════════════════════════════════════════════════════════════════

MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=

MYSQL_DB=bhetamla_db

# ═══════════════════════════════════════════════════════════════════════════
# FLASK CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

SECRET_KEY=bhetamla-secret-2024
FLASK_ENV=development

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION - OPTIONAL
# Leave these blank to skip email verification during testing
# ═══════════════════════════════════════════════════════════════════════════

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════

# 1. MYSQL_PASSWORD
#    - Find or reset your MySQL root password
#    - See quick_setup.py for MySQL reset instructions
#    - Example: MYSQL_PASSWORD=mypassword123

# 2. MAIL_USERNAME and MAIL_PASSWORD (Optional)
#    - For Gmail: Get an App Password after enabling 2FA
#    - Leave blank to disable email verification during testing
#    - Users will be auto-verified and can login immediately
