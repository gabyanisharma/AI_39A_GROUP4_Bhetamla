{% block extra_js %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
// ══════════════════════════════════════════════════════════════
//  ROUTE PLANNER — Meetup Integration
// ══════════════════════════════════════════════════════════════

const KTM = [27.7172, 85.3240];
const OSRM_BASE = 'https://router.project-osrm.org';

// ── State ────────────────────────────────────────────────────
let stops = [];          // [{name, lat, lng}]
let markers = [];        // Leaflet markers
let routeLayer = null;   // Leaflet polyline layer
let optMode = 'time';    // 'time' | 'distance'
let routeStats = { distance: 0, duration: 0 };
let dragSrcIdx = null;

// ── Preloaded Data ───────────────────────────────────────────
const preloadedRouteWaypoints = {{ route_waypoints|tojson|safe if route_waypoints else '[]' }};
const initialMidpoint = {% if midpoint_lat and midpoint_lng %}[{{ midpoint_lat }}, {{ midpoint_lng }}]{% else %}KTM{% endif %};

// ── Map Init ─────────────────────────────────────────────────
const map = L.map('rp-map').setView(initialMidpoint, 13);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '© OpenStreetMap contributors', maxZoom: 19
}).addTo(map);

// Click on map → add stop
map.on('click', function(e) {
  const { lat, lng } = e.latlng;
  setLoading(true);
  fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json`)
    .then(r => r.json())
    .then(d => {
      const name = d.display_name
        ? d.display_name.split(',').slice(0, 2).join(',').trim()
        : `${lat.toFixed(4)}, ${lng.toFixed(4)}`;
      addStop(name, lat, lng);
    })
    .catch(() => addStop(`${lat.toFixed(4)}, ${lng.toFixed(4)}`, lat, lng))
    .finally(() => setLoading(false));
});

// Load existing route if any
if (preloadedRouteWaypoints && preloadedRouteWaypoints.length > 0) {
  preloadedRouteWaypoints.forEach(w => addStop(w.name, w.lat, w.lng));
  calculateRoute();
}

// ── Loading helper ───────────────────────────────────────────
function setLoading(on) {
  document.getElementById('rp-loading').style.display = on ? 'block' : 'none';
}

// ── Add stop by search box ───────────────────────────────────
function addStopBySearch() {
  const q = document.getElementById('rp-stop-input').value.trim();
  if (!q) { showToast('Please enter a location name.'); return; }

  // Check if user entered lat,lng directly
  const coordMatch = q.match(/^(-?\d+\.?\d*)\s*,\s*(-?\d+\.?\d*)$/);
  if (coordMatch) {
    const lat = parseFloat(coordMatch[1]);
    const lng = parseFloat(coordMatch[2]);
    addStop(q, lat, lng);
    document.getElementById('rp-stop-input').value = '';
    return;
  }

  setLoading(true);
  fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&limit=1&countrycodes=np`)
    .then(r => r.json())
    .then(results => {
      if (!results.length) {
        showToast('Location not found. Try a more specific name.');
        return;
      }
      const r = results[0];
      const name = r.display_name.split(',').slice(0, 2).join(',').trim();
      addStop(name, parseFloat(r.lat), parseFloat(r.lon));
      document.getElementById('rp-stop-input').value = '';
    })
    .catch(() => showToast('Search failed. Try clicking the map.'))
    .finally(() => setLoading(false));
}

// ── Use current location ─────────────────────────────────────
function addCurrentLocation() {
  if (!navigator.geolocation) { showToast('Geolocation not supported.'); return; }
  setLoading(true);
  navigator.geolocation.getCurrentPosition(
    pos => {
      const lat = pos.coords.latitude, lng = pos.coords.longitude;
      fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json`)
        .then(r => r.json())
        .then(d => {
          const name = d.display_name
            ? d.display_name.split(',').slice(0, 2).join(',').trim()
            : 'My Location';
          addStop(name, lat, lng);
        })
        .catch(() => addStop('My Location', lat, lng))
        .finally(() => setLoading(false));
    },
    () => { showToast('Could not get location.'); setLoading(false); }
  );
}

// ── Core: add a stop ─────────────────────────────────────────
function addStop(name, lat, lng) {
  stops.push({ name, lat, lng });
  renderStopList();
  addMarker(lat, lng, stops.length);
  if (stops.length >= 2) fitMapToStops();
  updateStats(null);
}

// ── Remove a stop ────────────────────────────────────────────
function removeStop(idx) {
  stops.splice(idx, 1);
  rebuildMarkers();
  renderStopList();
  updateStats(null);
  if (routeLayer) { map.removeLayer(routeLayer); routeLayer = null; }
}

// ── Marker helpers ───────────────────────────────────────────
function addMarker(lat, lng, num) {
  const icon = L.divIcon({
    className: '',
    html: `<div style="
      background:var(--primary,#14322A);color:#fff;
      width:30px;height:30px;border-radius:50%;
      display:flex;align-items:center;justify-content:center;
      font-size:12px;font-weight:700;
      border:2.5px solid #fff;
      box-shadow:0 2px 8px rgba(0,0,0,.25);
    ">${num}</div>`,
    iconSize: [30, 30], iconAnchor: [15, 15]
  });
  const m = L.marker([lat, lng], { icon }).addTo(map);
  m.bindPopup(`<strong>Stop ${num}</strong><br>${stops[num-1]?.name || ''}`);
  markers.push(m);
}

function rebuildMarkers() {
  markers.forEach(m => map.removeLayer(m));
  markers = [];
  stops.forEach((s, i) => addMarker(s.lat, s.lng, i + 1));
}

function fitMapToStops() {
  if (!stops.length) return;
  const bounds = L.latLngBounds(stops.map(s => [s.lat, s.lng]));
  map.fitBounds(bounds, { padding: [50, 50] });
}

// ── Render the stop list ─────────────────────────────────────
function renderStopList() {
  const list = document.getElementById('rp-stop-list');
  const empty = document.getElementById('rp-empty-msg');
  const count = document.getElementById('rp-stop-count');
  const statStops = document.getElementById('stat-stops');

  count.textContent = `(${stops.length})`;
  statStops.textContent = stops.length;
  empty.style.display = stops.length ? 'none' : 'block';

  list.innerHTML = '';
  stops.forEach((s, i) => {
    if (i > 0) {
      const conn = document.createElement('div');
      conn.className = 'stop-connector';
      list.appendChild(conn);
    }
    const item = document.createElement('div');
    item.className = 'stop-item';
    item.draggable = true;
    item.dataset.idx = i;
    item.innerHTML = `
      <span class="stop-handle" title="Drag to reorder">⠿</span>
      <div class="stop-badge">${i + 1}</div>
      <div class="stop-name" title="${s.name}">${s.name}</div>
      <button class="stop-remove" onclick="removeStop(${i})" title="Remove stop">✕</button>
    `;
    // Drag-and-drop
    item.addEventListener('dragstart', onDragStart);
    item.addEventListener('dragover',  onDragOver);
    item.addEventListener('drop',      onDrop);
    item.addEventListener('dragend',   onDragEnd);
    list.appendChild(item);
  });
}

// ── Drag-and-drop reordering ─────────────────────────────────
function onDragStart(e) {
  dragSrcIdx = parseInt(this.dataset.idx);
  this.style.opacity = '0.5';
  e.dataTransfer.effectAllowed = 'move';
}
function onDragOver(e) {
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  document.querySelectorAll('.stop-item').forEach(el => el.classList.remove('drag-over'));
  this.classList.add('drag-over');
}
function onDrop(e) {
  e.stopPropagation();
  const destIdx = parseInt(this.dataset.idx);
  if (dragSrcIdx === destIdx) return;
  const moved = stops.splice(dragSrcIdx, 1)[0];
  stops.splice(destIdx, 0, moved);
  rebuildMarkers();
  renderStopList();
  if (routeLayer) { map.removeLayer(routeLayer); routeLayer = null; updateStats(null); }
}
function onDragEnd() {
  document.querySelectorAll('.stop-item').forEach(el => {
    el.classList.remove('drag-over');
    el.style.opacity = '1';
  });
  dragSrcIdx = null;
}

// ── Optimise mode ────────────────────────────────────────────
function setOptMode(mode) {
  optMode = mode;
  document.getElementById('opt-time').classList.toggle('active', mode === 'time');
  document.getElementById('opt-distance').classList.toggle('active', mode === 'distance');
}

// ── Calculate Route via OSRM ─────────────────────────────────
function calculateRoute() {
  if (stops.length < 2) { showToast('Add at least 2 stops first!'); return; }
  setLoading(true);

  const coords = stops.map(s => `${s.lng},${s.lat}`).join(';');
  const url = `${OSRM_BASE}/route/v1/driving/${coords}?overview=full&geometries=geojson&steps=false`;

  fetch(url)
    .then(r => r.json())
    .then(data => {
      if (data.code !== 'Ok') { showToast('Routing failed. Try again.'); return; }
      const route = data.routes[0];
      drawRoute(route.geometry.coordinates);
      updateStats({
        distance: route.distance / 1000,
        duration: Math.round(route.duration / 60)
      });
      showToast('✅ Route calculated successfully!');
    })
    .catch(() => showToast('Network error — could not reach routing server.'))
    .finally(() => setLoading(false));
}

// ── Optimise Stop Order via OSRM trip API ────────────────────
function optimiseRoute() {
  if (stops.length < 2) { showToast('Add at least 2 stops first!'); return; }
  if (stops.length > 10) { showToast('Optimisation supports up to 10 stops.'); return; }
  setLoading(true);

  const coords = stops.map(s => `${s.lng},${s.lat}`).join(';');
  const url = `${OSRM_BASE}/trip/v1/driving/${coords}?overview=full&geometries=geojson&source=first&roundtrip=false`;

  fetch(url)
    .then(r => r.json())
    .then(data => {
      if (data.code !== 'Ok') { showToast('Optimisation failed. Try Calculate instead.'); return; }

      // Re-order stops according to OSRM waypoint order
      const waypoints = data.waypoints.sort((a, b) => a.trips_index !== b.trips_index
        ? a.trips_index - b.trips_index
        : a.waypoint_index - b.waypoint_index);
      const newOrder = waypoints.map(w => w.waypoint_index);
      stops = newOrder.map(i => stops[i]);

      rebuildMarkers();
      renderStopList();

      const trip = data.trips[0];
      drawRoute(trip.geometry.coordinates);
      updateStats({
        distance: trip.distance / 1000,
        duration: Math.round(trip.duration / 60)
      });
      showToast('⚡ Stops optimised for ' + (optMode === 'time' ? 'fastest time' : 'shortest distance') + '!');
    })
    .catch(() => showToast('Network error during optimisation.'))
    .finally(() => setLoading(false));
}

// ── Draw route polyline on map ───────────────────────────────
function drawRoute(coords) {
  if (routeLayer) map.removeLayer(routeLayer);
  const latlngs = coords.map(c => [c[1], c[0]]);
  routeLayer = L.polyline(latlngs, {
    color: '#14322A', weight: 5, opacity: 0.8,
    dashArray: null,
    lineJoin: 'round'
  }).addTo(map);
  map.fitBounds(routeLayer.getBounds(), { padding: [40, 40] });
}

// ── Update stats panel ───────────────────────────────────────
function updateStats(data) {
  if (data) {
    routeStats = data;
    document.getElementById('stat-dist').textContent = data.distance.toFixed(1) + ' km';
    const h = Math.floor(data.duration / 60);
    const m = data.duration % 60;
    document.getElementById('stat-eta').textContent = h > 0 ? `${h}h ${m}m` : `${m} min`;
  } else {
    document.getElementById('stat-dist').textContent = '—';
    document.getElementById('stat-eta').textContent = '—';
  }
}

// ── Clear everything ─────────────────────────────────────────
function clearRoute() {
  stops = [];
  markers.forEach(m => map.removeLayer(m));
  markers = [];
  if (routeLayer) { map.removeLayer(routeLayer); routeLayer = null; }
  renderStopList();
  updateStats(null);
  showToast('Route cleared.');
}

// ── Save route ───────────────────────────────────────────────
function confirmSaveRoute() {
  if (stops.length < 2) { showToast('Add at least 2 stops before saving.'); return; }

  fetch('{{ url_for("meetup.route_save", meetup_id=meetup.id) }}', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      waypoints: stops,
      optimize_by: optMode,
      total_distance_km: routeStats.distance || 0,
      total_duration_min: routeStats.duration || 0
    })
  })
  .then(r => r.json())
  .then(d => {
    showToast(d.message || '✅ Route saved to meetup!');
  })
  .catch(() => showToast('Failed to save route.'));
}
</script>
{% endblock %}
